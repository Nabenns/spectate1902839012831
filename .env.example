DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Optional MT5 credentials (if your terminal already logged in, these can stay empty)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Optional absolute path to terminal64.exe / terminal binary
MT5_TERMINAL_PATH=

# Polling config
POLL_INTERVAL_SEC=3
HISTORY_SEED_HOURS=24
